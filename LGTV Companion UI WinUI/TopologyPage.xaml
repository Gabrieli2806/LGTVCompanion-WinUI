<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LGTVCompanionUI.TopologyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LGTVCompanionUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <StackPanel Spacing="12">
            <TextBlock Text="Multi-monitor topology configuration" Style="{StaticResource SubtitleTextBlockStyle}"/>

            <TextBlock Text="Step 1" Style="{StaticResource BodyStrongTextBlockStyle}" x:Name="Step1Label"/>
            <TextBlock Text="Ensure all your WebOS-devices are powered ON, connected to your PC and enabled (with an extended desktop in case of multiple displays)."
                       TextWrapping="Wrap" x:Name="Step1Description"/>

            <TextBlock Text="Step 2" Style="{StaticResource BodyStrongTextBlockStyle}" x:Name="Step2Label"/>
            <TextBlock Text="Open the Windows multi-monitor / display settings and determine which display number corresponds to your WebOS-device."
                       TextWrapping="Wrap" x:Name="Step2Description"/>

            <TextBlock Text="Step 3" Style="{StaticResource BodyStrongTextBlockStyle}" x:Name="Step3Label"/>
            <TextBlock Text="Click the Start button below and then proceed with matching each physical display to the corresponding configured device."
                       TextWrapping="Wrap" x:Name="Step3Description"/>

            <TextBlock Text="Step 4" Style="{StaticResource BodyStrongTextBlockStyle}" x:Name="Step4Label" Visibility="Collapsed"/>
            <TextBlock Text="Select the device which corresponds to this physical display:"
                       TextWrapping="Wrap" x:Name="Step4Description" Visibility="Collapsed"/>
            <ComboBox x:Name="DeviceMatchCombo" HorizontalAlignment="Stretch" Visibility="Collapsed"/>

            <TextBlock Text="Step 5" Style="{StaticResource BodyStrongTextBlockStyle}" x:Name="Step5Label" Visibility="Collapsed"/>
            <TextBlock Text="Configuration complete! Click Finish to save the topology configuration."
                       TextWrapping="Wrap" x:Name="Step5Description" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Status:" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Not configured!" Foreground="Red" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
