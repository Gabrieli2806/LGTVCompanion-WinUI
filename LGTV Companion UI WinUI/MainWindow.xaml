<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LGTVCompanionUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LGTVCompanionUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LGTV Companion">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- New version notification -->
        <HyperlinkButton x:Name="NewVersionLink" Grid.Row="0"
                         Content="New version is available. Click here to upgrade!"
                         Visibility="Collapsed"
                         Click="NewVersionLink_Click"
                         HorizontalAlignment="Center"/>

        <!-- Device selector and configure button -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="DeviceComboBox" Grid.Column="0"
                      HorizontalAlignment="Stretch"
                      FontSize="20"
                      SelectionChanged="DeviceComboBox_SelectionChanged"
                      IsEnabled="False"/>
            <SplitButton x:Name="ConfigureSplitButton" Grid.Column="1"
                         Content="Scan"
                         Click="ConfigureSplitButton_Click"
                         MinWidth="120">
                <SplitButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="MenuManage" Text="Configure" Click="MenuManage_Click"/>
                        <MenuFlyoutItem x:Name="MenuAdd" Text="Add" Click="MenuAdd_Click"/>
                        <MenuFlyoutItem x:Name="MenuScan" Text="Scan" Click="MenuScan_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuRemove" Text="Remove" Click="MenuRemove_Click"/>
                        <MenuFlyoutItem x:Name="MenuRemoveAll" Text="Remove all" Click="MenuRemoveAll_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuTest" Text="Test" Click="MenuTest_Click"/>
                        <MenuFlyoutItem x:Name="MenuTurnOn" Text="Turn on" Click="MenuTurnOn_Click"/>
                        <MenuFlyoutItem x:Name="MenuTurnOff" Text="Turn off" Click="MenuTurnOff_Click"/>
                    </MenuFlyout>
                </SplitButton.Flyout>
            </SplitButton>
        </Grid>

        <!-- Auto manage checkbox -->
        <CheckBox x:Name="EnableCheckBox" Grid.Row="2"
                  Content="Automatically manage this device"
                  IsEnabled="False"
                  Click="EnableCheckBox_Click"/>

        <!-- Spacer -->
        <Grid Grid.Row="3"/>

        <!-- Bottom row: Settings, Donate link, Apply -->
        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="SettingsButton" Grid.Column="0"
                    Content="Settings"
                    Click="SettingsButton_Click"/>
            <HyperlinkButton Grid.Column="1"
                             Content="Support your local Software Developer?"
                             HorizontalAlignment="Right"
                             Click="DonateLink_Click"/>
            <Button x:Name="ApplyButton" Grid.Column="2"
                    Content="Apply"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="False"
                    Click="ApplyButton_Click"/>
        </Grid>
    </Grid>
</Window>
